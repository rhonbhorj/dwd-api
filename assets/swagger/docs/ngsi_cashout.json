    "/generate-token": {
      "get": {
        "tags": [
          "Generate Token"
        ],
        "summary": "Generate Token",
        "description": "This view is for **Merchants**.\n\nIt uses **JWT** as the default authentication scheme.\n\nReturns a `token` if the user is authenticated.\n\nThe following headers are required:\n- `X-API-KEY`\n- `X-API-USERNAME`\n- `X-API-PASSWORD`\n\nTo access protected resources, set:\n\nHTTP_AUTHORIZATION: Bearer {{token}}",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "X-API-KEY",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "example": "{{X-API-KEY}}"
          },
