    "/v1/cashout": {
      "post": {
        "tags": [
          "Cashout"
        ],
        "summary": "Cashout Disbusment",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "reference_number": "1WY32456781581",
                  "callback_url": "https://api.ngsi-pgw-uat.netglobalsolutions.net/motify/service_requests",
                  "merchant_details": {
                    "txn_amount": 100,
                    "name": "johndoe",
                    "bank_code": "G-1001",
                    "account_number": "09213456789",
                    "txn_type": "2"
                  },
                  "email_confirmation": {
                    "email": "rhonbhorj@gmail.com",
                    "auto": "off"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "X-API-KEY",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "example": "{{X-API-KEY}}"
          },
          {
            "name": "X-API-USERNAME",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "example": "{{X-API-USERNAME}}"
          },
          {
            "name": "X-API-PASSWORD",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "example": "{{X-API-PASSWORD}}"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "headers": {
              "Content-Type": {
                "schema": {
                  "type": "string",
                  "example": "application/json"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": {
                  "status": true,
                  "message": "Transaction is on process.",
                  "data": {
                    "reference_number": "1WY32456781581",
                    "create_at": "2025-11-08T18:28:36.000+08:00",
                    "txn_ref": "3020251WY32456781581",
                    "txn_amount": "100"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "headers": {
              "Content-Type": {
                "schema": {
                  "type": "string",
                  "example": "application/json"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": {
                  "status": false,
                  "message": "Transaction with this client ref (1WY32456781581) already exists."
                }
              }
            }
          }
        }
      }
    },
