<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS, PUT, DELETE"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-API-KEY, X-API-USERNAME, X-API-PASSWORD"
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Handle OPTIONS (CORS preflight)
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^ - [R=200,L]

    # Block sensitive folders
    RewriteRule ^\.git - [F,L]
    RewriteRule ^\.vscode - [F,L]

    # Route all requests to index.php if not a real file/folder
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>

# Protect .env and similar files
<FilesMatch "^(\.env|composer\.lock)$">
    Require all denied
</FilesMatch>

# Extra protection for .env variants
<FilesMatch "\.env">
    Require all denied
</FilesMatch>


RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]